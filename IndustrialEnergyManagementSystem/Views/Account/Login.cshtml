@{
    ViewBag.Title = "Login";
    Layout = null; // 🔥 IMPORTANT: navbar remove for login page
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - IEMS</title>

    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #1f2937, #374151);
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-box {
            background: #ffffff;
            padding: 40px;
            border-radius: 12px;
            width: 350px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }

            .login-box h2 {
                text-align: center;
                margin-bottom: 25px;
                color: #1f2937;
            }

        .form-control {
            margin-bottom: 15px;
            border-radius: 8px;
        }

        .btn-login {
            width: 100%;
            background: #1f2937;
            color: white;
            border: none;
            padding: 10px;
            border-radius: 8px;
            font-weight: bold;
        }

            .btn-login:hover {
                background: #111827;
            }

        .error {
            color: red;
            text-align: center;
            margin-bottom: 10px;
        }
    </style>
</head>

<body>

    <div class="login-box">

        <h2>IEMS Login</h2>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Login", "Account", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <input type="text" name="username" class="form-control" placeholder="Username" required />

            <input type="password" name="password" class="form-control" placeholder="Password" required />

            <button type="submit" class="btn-login">Login</button>
        }

    </div>

</body>
</html>