@model IndustrialEnergyManagementSystem.Models.Machine

@{
    ViewBag.Title = "Delete Machine";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Delete Machine</h2>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Machine Details</h4>
    <hr />
    <dl class="dl-horizontal">
        <dt>Machine Name</dt>
        <dd>@Html.DisplayFor(model => model.MachineName)</dd>

        <dt>Power Rating (kW)</dt>
        <dd>@Html.DisplayFor(model => model.PowerRatingKW)</dd>

        <dt>Department</dt>
        <dd>@Model.Department?.DepartmentName</dd> <!-- Navigation property দিয়ে দেখানো হচ্ছে -->
    </dl>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.MachineId)

        <div class="form-actions no-color">
            <input type="submit" value="Delete" class="btn btn-danger" /> |
            @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
        </div>
    }
</div>