@model IndustrialEnergyManagementSystem.Models.EnergyLogViewModel

@{
    ViewBag.Title = "Delete Energy Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Delete Energy Log</h2>

<h4>Are you sure you want to delete this log?</h4>

<div>
    <dl class="dl-horizontal">
        <dt>Machine</dt>
        <dd>@Model.MachineName</dd>

        <dt>Run Hours</dt>
        <dd>@Model.RunHours</dd>

        <dt>Energy (kWh)</dt>
        <dd>@String.Format("{0:0.##}", Model.EnergyConsumed)</dd>

        <dt>Record Date</dt>
        <dd>@Model.RecordDate.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>
</div>

@using (Html.BeginForm("Delete", "Energy", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(model => model.RecordId)
    <input type="submit" value="Delete" class="btn btn-danger" />
    @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-default" })
}